<ul
  id="hamburger-menu-items"
  class="menu dropdown-content bg-base-100 border-base-300 rounded-box z-[60] w-56 border p-2 shadow-lg"
  tabindex="0"
  hx-swap-oob="true"
>
  <li>
    <a
      href="/theme/modal"
      hx-get="/theme/modal"
      hx-target="body"
      hx-swap="beforeend"
      _="on click wait 100ms then set #theme_modal.checked to true"
      aria-label="Theme"
      >Theme</a
    >
  </li>
  <li>
    <label for="about_modal" class="cursor-pointer" aria-label="About"
      >About</label
    >
  </li>
  <div class="divider my-1"></div>
  {{ if .IsAuthenticated }}
    <li>
      <a href="/dashboard?v={{ cacheVersion }}" aria-label="Dashboard"
        >Dashboard</a
      >
    </li>
    <li>
      <a
        href="/config?v={{ cacheVersion }}"
        hx-get="/config"
        hx-target="body"
        hx-swap="beforeend"
        _="on click wait 100ms then set #config_modal.checked to true"
        aria-label="Configuration"
        >Configuration</a
      >
    </li>
    {{/* Server submenu using DaisyUI collapse */}}
    <li>
      <details class="bg-base-100 collapse-arrow collapse">
        <summary class="collapse-title min-h-0 py-2 text-sm font-medium">
          Server
        </summary>
        <div class="collapse-content">
          <ul class="menu menu-compact">
            <li>
              <label
                for="shutdown_modal"
                class="text-error cursor-pointer"
                aria-label="Shutdown"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-4 w-4"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M13 10V3L4 14h7v7l9-11h-7z"
                  />
                </svg>
                Shutdown
              </label>
            </li>
            <li>
              <button
                hx-post="/server/discovery"
                hx-target="#server-toast-container"
                hx-swap="innerHTML"
                class="text-success"
                aria-label="Run Discovery"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-4 w-4"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"
                  />
                </svg>
                Run Discovery
              </button>
            </li>
          </ul>
        </div>
      </details>
    </li>
    <div class="divider my-1"></div>
    <li>
      <label for="logout_modal" class="cursor-pointer" aria-label="Logout"
        >Logout</label
      >
    </li>
  {{ else }}
    <li>
      <label for="login_modal" class="cursor-pointer" aria-label="Login"
        >Login</label
      >
    </li>
  {{ end }}
</ul>
