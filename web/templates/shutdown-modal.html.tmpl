<!-- Shutdown Confirmation Modal (DaisyUI) -->
<input type="checkbox" id="shutdown_modal" class="modal-toggle" />
<div class="modal" role="dialog">
  <div class="modal-box">
    <h3 class="text-error mb-4 text-lg font-bold">Confirm Shutdown</h3>
    <div class="alert alert-warning mb-4">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-6 w-6 shrink-0 stroke-current"
        fill="none"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"
        />
      </svg>
      <span
        >Are you sure you want to shut down the server? This action cannot be
        undone.</span
      >
    </div>
    <p class="text-base-content/70 mb-4 text-sm">
      All pending operations will be completed before shutdown. The server will
      be unavailable until manually restarted.
    </p>
    <form
      id="shutdown-form"
      hx-post="/server/shutdown"
      hx-target="body"
      hx-swap="innerHTML"
    >
      <input type="hidden" name="csrf_token" value="{{ .CSRFToken }}" />
      <div class="modal-action">
        <button class="btn btn-error" type="submit">Shutdown Server</button>
        <label for="shutdown_modal" class="btn">Cancel</label>
      </div>
    </form>
  </div>
  <label class="modal-backdrop" for="shutdown_modal">Close</label>
</div>
