{{ define "infobox-folder.html.tmpl" }}
  <div id="inner_box_info" class="m-2 text-xs" data-info-id="{{ .Folder.ID }}">
    <div class="card bg-base-200 mb-3 shadow-sm">
      <figure class="bg-base-300 flex h-40 items-center justify-center">
        <img
          class="max-w-full rounded-[3px] object-cover"
          src="/thumbnail/folder/{{ .Folder.ID }}"
          alt="{{ .Folder.Name }}"
        />
      </figure>
    </div>

    <div class="card bg-base-200 mb-3 shadow-sm">
      <div class="card-body p-3">
        <h3 class="card-title text-xs">Gallery Name</h3>
        <p class="break-words">{{ .Folder.Name }}</p>
      </div>
    </div>

    <div class="card bg-base-200 mb-3 shadow-sm">
      <div class="card-body p-3">
        <h3 class="card-title text-xs">Information</h3>
        <div class="space-y-1">
          <div>
            <span class="text-base-content/70">Date:</span>
            <span id="folder-mtime">{{ .FormattedMtime }}</span>
          </div>
          {{ if .DirCount }}
            <div>
              <span class="text-base-content/70">Directories:</span>
              <span id="folder-dir-count">{{ .DirCount }}</span>
            </div>
          {{ end }}
          {{ if .ImageCount }}
            <div>
              <span class="text-base-content/70">Images:</span>
              <span id="folder-image-count">{{ .ImageCount }}</span>
            </div>
          {{ end }}
          {{ if .FileCount }}
            <div>
              <span class="text-base-content/70">Files:</span>
              <span id="folder-file-count">{{ .FileCount }}</span>
            </div>
          {{ end }}
        </div>
      </div>
    </div>
  </div>
{{ end }}
