<form
  id="login-form"
  class="card-body"
  hx-post="/login"
  hx-swap="none"
  hx-swap-oob="true"
>
  <input type="hidden" name="csrf_token" value="{{ .CSRFToken }}" />
  <div id="login-error-message" class="text-error">{{ .ErrorMessage }}</div>
  <div class="form-control">
    <label class="label">
      <span class="label-text">Username</span>
    </label>
    <input
      type="text"
      name="username"
      placeholder="username"
      class="input input-bordered"
      required
      value="{{ .Username }}"
    />
  </div>
  <div class="form-control">
    <label class="label">
      <span class="label-text">Password</span>
    </label>
    <input
      type="password"
      name="password"
      placeholder="password"
      class="input input-bordered"
      required
    />
  </div>
  <div class="form-control mt-6">
    <button class="btn btn-primary">Login</button>
  </div>
</form>
