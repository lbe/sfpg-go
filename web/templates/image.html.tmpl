{{ define "body" }}
  <div id="imageContainer" class="mx-auto flex-1 overflow-hidden p-0">
    <div
      id="imageWrapper"
      class="flex h-[calc(100vh-10rem)] items-center justify-center p-1 wrap-break-word"
    >
      <img
        src="/raw-image/{{ .ImageID }}?v={{ .CacheVersion }}"
        alt="Full size image: {{ .ImagePath }}"
        aria-label="Full size image view"
        class="box-content inline max-h-full max-w-full overflow-clip border-[0.33rem] object-contain"
      />
    </div>
  </div>
{{ end }}
