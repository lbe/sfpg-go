<!-- Configuration Modal - Loaded on demand via HTMX -->
<div id="config-modal-container">
  <input type="checkbox" id="config_modal" class="modal-toggle" />
  <div class="modal" role="dialog">
    <div
      class="modal-box flex h-[90vh] w-11/12 max-w-5xl flex-col overflow-hidden p-0"
    >
      <!-- Fixed Header -->
      <div
        class="border-base-300 flex flex-shrink-0 items-center justify-between border-b p-6 pb-4"
      >
        <h3 class="text-2xl font-bold">Configuration</h3>
        <label
          for="config_modal"
          class="btn btn-sm btn-circle btn-ghost"
          _="on click
                  wait 300ms
                  remove #config-modal-container from body"
          >✕</label
        >
      </div>

      <!-- Alert area for messages (OOB updates) -->
      <div id="config-alerts" class="flex-shrink-0 px-6 pt-2"></div>
      <div id="restart-warning" class="hidden flex-shrink-0 px-6 pt-2"></div>
      <div id="config-success-message" class="flex-shrink-0 px-6 pt-2"></div>

      <!-- Form wraps everything -->
      <form
        id="config-form"
        hx-post="/config"
        hx-target="#config-success-message"
        hx-swap="outerHTML"
        hx-indicator="#config-loading"
        class="flex min-h-0 flex-1 flex-col overflow-hidden"
        _="on htmx:afterSwap
               if #config-error-message.innerHTML.trim() != ''
                 remove .htmx-request from me
                 remove .htmx-request from body
                 add .hidden to #config-spinner
               end
            on htmx:afterSettle
               if #config-error-message.innerHTML.trim() != ''
                 remove .htmx-request from me
                 remove .htmx-request from body
                 add .hidden to #config-spinner
               end
            on htmx:afterRequest
               wait 10ms
               if #config-error-message.innerHTML.trim() != ''
                 remove .htmx-request from me
                 remove .htmx-request from body
                 add .hidden to #config-spinner
               end"
      >
        <input type="hidden" name="csrf_token" value="{{ .CSRFToken }}" />
        <div
          id="config-error-message"
          class="text-error mb-4 px-6"
          _="on htmx:afterSwap from me
                remove .htmx-request from #config-form
                remove .htmx-request from body
                add .hidden to #config-spinner
             on load
                remove .htmx-request from #config-form
                remove .htmx-request from body
                add .hidden to #config-spinner
             on mutation
                if my.innerHTML.trim() != ''
                  remove .htmx-request from #config-form
                  remove .htmx-request from body
                  add .hidden to #config-spinner
                end"
        ></div>

        <!-- Fixed Tabs Navigation -->
        <div role="tablist" class="tabs tabs-boxed mx-6 mb-4 flex-shrink-0">
          <button
            id="tab-server-btn"
            type="button"
            role="tab"
            class="tab tab-active"
            data-tab="tab-server"
            aria-controls="tab-server"
            aria-selected="true"
            _="on click 
                     set targetPanelId to my.getAttribute('data-tab')
                     set targetPanel to document.getElementById(targetPanelId)
                     set tabList to me.closest('[role=tablist]')
                     set allTabs to tabList.querySelectorAll('button[role=tab]')
                     for tab in allTabs
                       remove .tab-active from tab
                       set tab@aria-selected to 'false'
                     end
                     add .tab-active to me
                     set my@aria-selected to 'true'
                     add .hidden to <.tab-panel/> in #tab-panels
                     remove .hidden from targetPanel"
          >
            Server
          </button>
          <button
            id="tab-logging-btn"
            type="button"
            role="tab"
            class="tab"
            data-tab="tab-logging"
            aria-controls="tab-logging"
            aria-selected="false"
            _="on click 
                     set targetPanelId to my.getAttribute('data-tab')
                     set targetPanel to document.getElementById(targetPanelId)
                     set tabList to me.closest('[role=tablist]')
                     set allTabs to tabList.querySelectorAll('button[role=tab]')
                     for tab in allTabs
                       remove .tab-active from tab
                       set tab@aria-selected to 'false'
                     end
                     add .tab-active to me
                     set my@aria-selected to 'true'
                     add .hidden to <.tab-panel/> in #tab-panels
                     remove .hidden from targetPanel"
          >
            Logging
          </button>
          <button
            id="tab-application-btn"
            type="button"
            role="tab"
            class="tab"
            data-tab="tab-application"
            aria-controls="tab-application"
            aria-selected="false"
            _="on click 
                     set targetPanelId to my.getAttribute('data-tab')
                     set targetPanel to document.getElementById(targetPanelId)
                     set tabList to me.closest('[role=tablist]')
                     set allTabs to tabList.querySelectorAll('button[role=tab]')
                     for tab in allTabs
                       remove .tab-active from tab
                       set tab@aria-selected to 'false'
                     end
                     add .tab-active to me
                     set my@aria-selected to 'true'
                     add .hidden to <.tab-panel/> in #tab-panels
                     remove .hidden from targetPanel"
          >
            Application
          </button>
          <button
            id="tab-session-btn"
            type="button"
            role="tab"
            class="tab"
            data-tab="tab-session"
            aria-controls="tab-session"
            aria-selected="false"
            _="on click 
                     set targetPanelId to my.getAttribute('data-tab')
                     set targetPanel to document.getElementById(targetPanelId)
                     set tabList to me.closest('[role=tablist]')
                     set allTabs to tabList.querySelectorAll('button[role=tab]')
                     for tab in allTabs
                       remove .tab-active from tab
                       set tab@aria-selected to 'false'
                     end
                     add .tab-active to me
                     set my@aria-selected to 'true'
                     add .hidden to <.tab-panel/> in #tab-panels
                     remove .hidden from targetPanel"
          >
            Session
          </button>
          <button
            id="tab-performance-btn"
            type="button"
            role="tab"
            class="tab"
            data-tab="tab-performance"
            aria-controls="tab-performance"
            aria-selected="false"
            _="on click 
                     set targetPanelId to my.getAttribute('data-tab')
                     set targetPanel to document.getElementById(targetPanelId)
                     set tabList to me.closest('[role=tablist]')
                     set allTabs to tabList.querySelectorAll('button[role=tab]')
                     for tab in allTabs
                       remove .tab-active from tab
                       set tab@aria-selected to 'false'
                     end
                     add .tab-active to me
                     set my@aria-selected to 'true'
                     add .hidden to <.tab-panel/> in #tab-panels
                     remove .hidden from targetPanel"
          >
            Performance
          </button>
          <button
            id="tab-discovery-btn"
            type="button"
            role="tab"
            class="tab"
            data-tab="tab-discovery"
            aria-controls="tab-discovery"
            aria-selected="false"
            _="on click 
                     set targetPanelId to my.getAttribute('data-tab')
                     set targetPanel to document.getElementById(targetPanelId)
                     set tabList to me.closest('[role=tablist]')
                     set allTabs to tabList.querySelectorAll('button[role=tab]')
                     for tab in allTabs
                       remove .tab-active from tab
                       set tab@aria-selected to 'false'
                     end
                     add .tab-active to me
                     set my@aria-selected to 'true'
                     add .hidden to <.tab-panel/> in #tab-panels
                     remove .hidden from targetPanel"
          >
            Discovery
          </button>
          <button
            id="tab-admin-btn"
            type="button"
            role="tab"
            class="tab"
            data-tab="tab-admin"
            aria-controls="tab-admin"
            aria-selected="false"
            _="on click 
                     set targetPanelId to my.getAttribute('data-tab')
                     set targetPanel to document.getElementById(targetPanelId)
                     set tabList to me.closest('[role=tablist]')
                     set allTabs to tabList.querySelectorAll('button[role=tab]')
                     for tab in allTabs
                       remove .tab-active from tab
                       set tab@aria-selected to 'false'
                     end
                     add .tab-active to me
                     set my@aria-selected to 'true'
                     add .hidden to <.tab-panel/> in #tab-panels
                     remove .hidden from targetPanel"
          >
            Admin ID
          </button>
        </div>

        <!-- Scrollable Tab Content -->
        <div id="tab-panels" class="min-h-0 flex-1 overflow-y-auto px-6 pb-6">
          <div
            id="tab-server"
            role="tabpanel"
            aria-labelledby="tab-server-btn"
            class="tab-panel bg-base-100 border-base-300 rounded-box border p-6"
          >
            {{ template "config-server-tab" . }}
          </div>
          <div
            id="tab-logging"
            role="tabpanel"
            aria-labelledby="tab-logging-btn"
            class="tab-panel bg-base-100 border-base-300 rounded-box hidden border p-6"
          >
            {{ template "config-logging-tab" . }}
          </div>
          <div
            id="tab-application"
            role="tabpanel"
            aria-labelledby="tab-application-btn"
            class="tab-panel bg-base-100 border-base-300 rounded-box hidden border p-6"
          >
            {{ template "config-application-tab" . }}
          </div>
          <div
            id="tab-session"
            role="tabpanel"
            aria-labelledby="tab-session-btn"
            class="tab-panel bg-base-100 border-base-300 rounded-box hidden border p-6"
          >
            {{ template "config-session-tab" . }}
          </div>
          <div
            id="tab-performance"
            role="tabpanel"
            aria-labelledby="tab-performance-btn"
            class="tab-panel bg-base-100 border-base-300 rounded-box hidden border p-6"
          >
            {{ template "config-performance-tab" . }}
          </div>
          <div
            id="tab-discovery"
            role="tabpanel"
            aria-labelledby="tab-discovery-btn"
            class="tab-panel bg-base-100 border-base-300 rounded-box hidden border p-6"
          >
            {{ template "config-discovery-tab" . }}
          </div>
          <div
            id="tab-admin"
            role="tabpanel"
            aria-labelledby="tab-admin-btn"
            class="tab-panel bg-base-100 border-base-300 rounded-box hidden border p-6"
          >
            {{ template "config-admin-tab" . }}
          </div>
        </div>
      </form>

      <!-- Fixed Footer with buttons and info area -->
      <div class="border-base-300 flex-shrink-0 border-t p-6 pt-4">
        <!-- Button explanation and badge area (fixed height) -->
        <div class="mb-2 flex h-8 items-center justify-end">
          <div class="flex items-center gap-2">
            <div
              id="button-explanation-text"
              class="text-base-content/70 w-[452px] overflow-hidden text-center text-sm text-ellipsis whitespace-nowrap"
            ></div>
            <div
              id="button-explanation-area-right"
              class="flex items-center justify-center"
            >
              <span id="config-restart-badge" class="badge badge-warning hidden"
                >Restart Required</span
              >
            </div>
          </div>
        </div>

        <!-- Footer with buttons (right-aligned) -->
        <div class="modal-action justify-end">
          <div class="flex items-center gap-2">
            <button
              class="btn btn-outline btn-sm"
              hx-post="/config/restore-last-known-good?action=preview"
              hx-target="#restore-diff-modal"
              hx-swap="innerHTML"
              _="on mouseenter set #button-explanation-text.textContent to 'Restore the last known good configuration from the database' on mouseleave set #button-explanation-text.textContent to ''"
            >
              Restore
            </button>
            <button
              class="btn btn-outline btn-primary btn-sm"
              hx-post="/config/export/to-file"
              hx-target="#export-diff-modal"
              hx-swap="innerHTML"
              _="on mouseenter set #button-explanation-text.textContent to 'Export current configuration to a YAML file for backup' on mouseleave set #button-explanation-text.textContent to ''"
            >
              Export
            </button>
            <a
              class="btn btn-outline btn-primary btn-sm"
              href="/config/export/download"
              download="config.yaml"
              _="on mouseenter set #button-explanation-text.textContent to 'Download current configuration as a YAML file' on mouseleave set #button-explanation-text.textContent to ''"
            >
              Download
            </a>
            <button
              class="btn btn-outline btn-primary btn-sm"
              _="on click click() on #import-file-input on mouseenter set #button-explanation-text.textContent to 'Import configuration from a YAML file' on mouseleave set #button-explanation-text.textContent to ''"
            >
              Import
            </button>
            <input
              type="file"
              id="import-file-input"
              accept=".yaml,.yml"
              class="hidden"
              hx-post="/config/import/preview"
              hx-target="#import-diff-modal"
              hx-swap="innerHTML"
              hx-trigger="change"
              hx-encoding="multipart/form-data"
              name="yaml"
              _="on change
                if my.files.length > 0
                  set #import-diff-modal-toggle.checked to true
                end"
            />
            <button
              type="button"
              class="btn btn-sm"
              id="config-cancel-btn"
              _="on click
                set hasChanges to false
                set configFields to ['listener_address', 'listener_port', 'server_compression_enable',
                                     'log_directory', 'log_level', 'log_rollover', 'log_retention_count',
                                     'site_name', 'image_directory', 'current_theme',
                                     'session_max_age', 'session_http_only', 'session_secure', 'session_same_site',
                                     'enable_http_cache', 'enable_cache_preload', 'cache_max_size', 'cache_max_entry_size', 'cache_max_time', 'cache_cleanup_interval',
                                     'db_max_pool_size', 'db_min_idle_connections', 'db_optimize_interval',
                                     'worker_pool_max', 'worker_pool_min_idle', 'worker_pool_max_idle_time', 'queue_size',
                                     'run_file_discovery']
                
                set form to #config-form
                if form and window.configOriginalValues
                  for fieldName in configFields
                    set field to form.querySelector('[name=' + fieldName + ']')
                    if field
                      set originalValue to window.configOriginalValues[fieldName]
                      if originalValue is not undefined
                        set currentValue to null
                        if field.type == 'checkbox'
                          set currentValue to field.checked
                        else
                          set currentValue to field.value
                        end
                        
                        set origStr to String(originalValue)
                        set currStr to String(currentValue)
                        
                        if origStr != currStr
                          set hasChanges to true
                        end
                      end
                    end
                  end
                  
                  -- Check themes
                  set themesSelect to form.querySelector('select[name=themes]')
                  if themesSelect
                    set originalThemes to window.configOriginalValues['themes']
                    set origThemesStr to ''
                    set currThemesStr to ''
                    
                    if originalThemes and originalThemes.length > 0
                      for theme in originalThemes
                        if origThemesStr != '' set origThemesStr to origThemesStr + ', ' end
                        set origThemesStr to origThemesStr + theme
                      end
                    end
                    
                    set selectedOptions to themesSelect.selectedOptions
                    set firstTheme to true
                    for option in selectedOptions
                      if not firstTheme set currThemesStr to currThemesStr + ', ' end
                      set currThemesStr to currThemesStr + option.value
                      set firstTheme to false
                    end
                    
                    if origThemesStr == '' set origThemesStr to '(none)' end
                    if currThemesStr == '' set currThemesStr to '(none)' end
                    
                    if origThemesStr != currThemesStr
                      set hasChanges to true
                    end
                  end
                end
                
                if hasChanges
                  call buildConfigDiff(configFields, #cancel-diff-content, true)
                  set #cancel-diff-modal.checked to true
                else
                  set #config_modal.checked to false
                  wait 300ms
                  remove #config-modal-container from body
                end"
            >
              Cancel
            </button>
            <button
              type="submit"
              form="config-form"
              class="btn btn-primary btn-sm relative text-center"
              id="config-loading"
            >
              <span class="text-center">Save Settings</span>
              <span
                id="config-spinner"
                class="loading loading-spinner loading-sm htmx-indicator absolute inset-0 flex items-center justify-center"
              ></span>
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Modals for diff display -->
    <input
      type="checkbox"
      id="restore-diff-modal-toggle"
      class="modal-toggle"
    />
    <div id="restore-diff-modal" class="modal" role="dialog"></div>
    <input type="checkbox" id="export-diff-modal-toggle" class="modal-toggle" />
    <div id="export-diff-modal" class="modal" role="dialog"></div>
    <input type="checkbox" id="import-diff-modal-toggle" class="modal-toggle" />
    <div id="import-diff-modal" class="modal" role="dialog"></div>
    <input type="checkbox" id="cancel-diff-modal" class="modal-toggle" />
    <div class="modal" role="dialog">
      <div class="modal-box max-w-4xl">
        <h3 class="mb-4 text-lg font-bold">Unsaved Changes</h3>
        <p class="mb-4">
          You have unsaved changes. Are you sure you want to cancel?
        </p>
        <div
          id="cancel-diff-content"
          class="border-base-300 mb-4 max-h-96 overflow-y-auto rounded border p-4"
        >
          <!-- Diff content will be inserted here -->
        </div>
        <div class="modal-action">
          <label
            for="cancel-diff-modal"
            class="btn btn-primary"
            _="on click
              set #config_modal.checked to false
              wait 300ms
              remove #config-modal-container from body"
            >Discard Changes</label
          >
          <label for="cancel-diff-modal" class="btn">Keep Editing</label>
        </div>
      </div>
      <label class="modal-backdrop" for="cancel-diff-modal"></label>
    </div>
    <input type="checkbox" id="restart-diff-modal" class="modal-toggle" />
    <div class="modal" role="dialog">
      <div class="modal-box max-w-4xl">
        <h3 class="mb-4 text-lg font-bold">Restart Required</h3>
        <p class="mb-4">
          Some settings require a server restart to take effect. The following
          changes will be applied after restart:
        </p>
        <div
          id="restart-diff-content"
          class="border-base-300 mb-4 max-h-96 overflow-y-auto rounded border p-4"
        >
          <!-- Diff content will be inserted here -->
        </div>
        <div class="modal-action">
          <button
            class="btn btn-primary"
            hx-post="/config/restart"
            hx-target="#config-success-message"
            hx-swap="outerHTML"
            hx-vals='{"csrf_token": "{{ .CSRFToken }}"}'
            _="on htmx:afterRequest
                 -- Close the restart dialog
                 set #restart-diff-modal.checked to false
                 -- Close the config modal
                 set #config_modal.checked to false
                 -- Remove the config modal container after a brief delay
                 wait 100ms
                 remove #config-modal-container from body
                 -- Show the restart overlay
                 send showRestartOverlay to #restart-overlay"
          >
            Restart Server
          </button>
          <label for="restart-diff-modal" class="btn">Close</label>
        </div>
      </div>
      <label class="modal-backdrop" for="restart-diff-modal"></label>
    </div>

    <label
      class="modal-backdrop"
      for="config_modal"
      _="on click
              wait 300ms
              remove #config-modal-container from body"
    ></label>
  </div>
</div>

<script type="text/hyperscript">
  def buildConfigDiff(fieldList, targetElement, includeThemes)
    set changesHTML to '<table class="table table-compact w-full"><thead><tr><th>Setting</th><th>Current Value</th><th>Unsaved Value</th></tr></thead><tbody>'

    set form to #config-form
    if form and window.configOriginalValues
      for fieldName in fieldList
        set field to form.querySelector(`[name='${fieldName}']`)
        if field
          set originalValue to window.configOriginalValues[fieldName]
          if originalValue is not undefined
            set currentValue to null
            if field.type == 'checkbox'
              set currentValue to field.checked
            else
              set currentValue to field.value
            end

            set origStr to String(originalValue)
            set currStr to String(currentValue)

            if origStr != currStr
              set changesHTML to `${changesHTML}<tr><td class="font-semibold">${fieldName}</td><td class="text-base-content">${origStr}</td><td class="text-warning">${currStr}</td></tr>`
            end
          end
        end
      end

      if includeThemes
        -- Special handling for themes (multi-select)
        set themesSelect to form.querySelector('select[name=themes]')
        if themesSelect
          set originalThemes to window.configOriginalValues['themes']
          set origThemesStr to ''
          set currThemesStr to ''

          -- Build original themes string
          if originalThemes and originalThemes.length > 0
            for theme in originalThemes
              if origThemesStr != '' set origThemesStr to `${origThemesStr}, ` end
              set origThemesStr to `${origThemesStr}${theme}`
            end
          end

          -- Build current themes string
          set selectedOptions to themesSelect.selectedOptions
          set firstTheme to true
          for option in selectedOptions
            if not firstTheme set currThemesStr to `${currThemesStr}, ` end
            set currThemesStr to `${currThemesStr}${option.value}`
            set firstTheme to false
          end

          if origThemesStr == '' set origThemesStr to '(none)' end
          if currThemesStr == '' set currThemesStr to '(none)' end

          if origThemesStr != currThemesStr
            set changesHTML to `${changesHTML}<tr><td class="font-semibold">themes</td><td class="text-base-content">${origThemesStr}</td><td class="text-warning">${currThemesStr}</td></tr>`
          end
        end
      end
    end

    set changesHTML to `${changesHTML}</tbody></table>`
    set targetElement.innerHTML to changesHTML
  end

  -- Listen for HTMX settle events (fires after all OOB swaps complete) to trigger restart modal
  on htmx:afterSettle from document
    set badge to #config-restart-badge
    -- Check if badge exists first, then check visibility and content
    if badge is not null
      if badge.textContent == 'Restart Required' and badge.classList.contains('hidden') == false and badge.classList.contains('restart-modal-shown') == false
        wait 100ms
        set configFields to ['listener_address', 'listener_port', 'server_compression_enable', 'log_directory', 'log_level', 'log_rollover', 'log_retention_count', 'site_name', 'image_directory', 'current_theme', 'session_max_age', 'session_http_only', 'session_secure', 'session_same_site', 'enable_http_cache', 'enable_cache_preload', 'cache_max_size', 'cache_max_entry_size', 'cache_max_time', 'cache_cleanup_interval', 'db_max_pool_size', 'db_min_idle_connections', 'db_optimize_interval', 'worker_pool_max', 'worker_pool_min_idle', 'worker_pool_max_idle_time', 'queue_size', 'run_file_discovery']
        call buildConfigDiff(configFields, #restart-diff-content, true)
        wait 200ms
        set #restart-diff-modal.checked to true
        -- Mark that we've shown the modal so we don't re-trigger
        add .restart-modal-shown to badge
      end
    end
  end

    -- Store original form values when modal opens
    init
      set window.configOriginalValues to {}
      set form to #config-form
      if form
        -- Use selector to find all named inputs/selects (using JS to avoid Go template escaping)
        set allFields to form.querySelectorAll('[name]')

        for field in allFields
          set fieldName to field@name
          if field.type == 'checkbox'
            set window.configOriginalValues[fieldName] to field.checked
          else
            set window.configOriginalValues[fieldName] to field.value
          end
        end

        -- Special handling for themes (multi-select)
        set themesSelect to form.querySelector('select[name=themes]')
        if themesSelect
          set selectedOptions to themesSelect.selectedOptions
          set themesArray to []
          for option in selectedOptions
            set themesArray to themesArray.concat([option.value])
          end
          set window.configOriginalValues['themes'] to themesArray
        end
      end
    end

    -- Track changes to show/hide restart required badge
    on change from #config-form
      set needsRestart to false
      set form to #config-form

      -- Get the field that triggered the change
      set changedField to event.target
      set changedFieldName to changedField.getAttribute('name')

      -- Ignore admin credential fields - they never require restart
      set adminFields to ['admin_username', 'admin_current_password', 'admin_new_password', 'admin_confirm_password']
      if changedFieldName in adminFields
        -- Admin fields changed, but don't trigger restart badge
        exit
      end

      if form and window.configOriginalValues
        -- Find all fields that have the data-requires-restart attribute
        set restartFields to form.querySelectorAll('[data-requires-restart="true"]')
        for field in restartFields
          set fieldName to field@name
          set originalValue to window.configOriginalValues[fieldName]
          if originalValue is not undefined
            if field.type == 'checkbox'
              if field.checked != originalValue set needsRestart to true end
            else
              if field.value != originalValue set needsRestart to true end
            end
          end
        end
      -- Themes also requires restart (hardcoded check since it's a special multi-select)
      set themesSelect to form.querySelector('select[name=themes]')
      if themesSelect
        set originalThemes to window.configOriginalValues['themes']
        set selectedOptions to themesSelect.selectedOptions

        if originalThemes and originalThemes.length != selectedOptions.length
          set needsRestart to true
        else if originalThemes
          for option in selectedOptions
            if originalThemes.indexOf(option.value) == -1
              set needsRestart to true
            end
          end
        end
      end
    end

