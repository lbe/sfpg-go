    <div class="form-control mb-4">
      <label class="label">
        <span class="label-text font-semibold">Cache Max Time</span>
      </label>
      <input
        type="text"
        name="cache_max_time"
        data-requires-restart="true"
        placeholder="720h"
        class="input input-bordered w-32"
        value="{{ if .Config }}{{ .Config.CacheMaxTime }}{{ end }}"
      />
      <label class="label">
        <span class="label-text-alt">
          {{ if index .HelpText "cache_max_time" }}
            {{ index .HelpText "cache_max_time" }}
            {{ if index .ExampleValue "cache_max_time" }}
              (Examples: {{ index .ExampleValue "cache_max_time" }})
            {{ end }}
          {{ else if index .ExampleValue "cache_max_time" }}
            Examples:
            {{ index .ExampleValue "cache_max_time" }}
          {{ else }}
            Cache TTL as duration (e.g., 720h = 30 days, 5m = 5 minutes).
            Restart required.
          {{ end }}
        </span>
      </label>
    </div>

    <div class="form-control mb-4">
      <label class="label">
        <span class="label-text font-semibold">Cache Cleanup Interval</span>
      </label>
      <input
        type="text"
        name="cache_cleanup_interval"
        data-requires-restart="true"
        placeholder="5m"
        class="input input-bordered w-32"
        value="{{ if .Config }}{{ .Config.CacheCleanupInterval }}{{ end }}"
      />
      <label class="label">
        <span class="label-text-alt"
          >How often to clean expired cache entries (e.g., 5m = 5 minutes).
          Restart required.</span
        >
      </label>
    </div>
  </fieldset>

  <fieldset
    class="fieldset border-base-300 bg-base-200/30 mb-6 rounded-lg border p-4"
  >
    <legend class="fieldset-legend text-base font-semibold">DB Pool</legend>
    <div class="form-control mb-4">
      <label class="label">
        <span class="label-text font-semibold">DB Max Pool Size</span>
      </label>
      <input
        type="number"
        name="db_max_pool_size"
        data-requires-restart="true"
        placeholder="100"
        class="input input-bordered w-24"
        min="1"
        value="{{ if .Config }}{{ .Config.DBMaxPoolSize }}{{ end }}"
      />
      <label class="label">
        <span class="label-text-alt"
          >Maximum database connections in pool. Restart required.</span
        >
      </label>
    </div>

    <div class="form-control mb-4">
      <label class="label">
        <span class="label-text font-semibold">DB Min Idle Connections</span>
      </label>
      <input
        type="number"
        name="db_min_idle_connections"
        data-requires-restart="true"
        placeholder="10"
        class="input input-bordered w-24"
        min="0"
        value="{{ if .Config }}{{ .Config.DBMinIdleConnections }}{{ end }}"
      />
      <label class="label">
        <span class="label-text-alt"
          >Minimum idle connections to maintain. Restart required.</span
        >
      </label>
    </div>

    <div class="form-control mb-4">
      <label class="label">
        <span class="label-text font-semibold">DB Optimize Interval</span>
      </label>
      <input
        type="text"
        name="db_optimize_interval"
        data-requires-restart="true"
        placeholder="1h"
        class="input input-bordered w-32"
        value="{{ if .Config }}{{ .Config.DBOptimizeInterval }}{{ end }}"
      />
      <label class="label">
        <span class="label-text-alt"
          >How often to run SQLite OPTIMIZE (e.g., 1h = 1 hour). Restart
          required.</span
        >
      </label>
    </div>
  </fieldset>

  <fieldset
    class="fieldset border-base-300 bg-base-200/30 mb-6 rounded-lg border p-4"
  >
    <legend class="fieldset-legend text-base font-semibold">Worker Pool</legend>
    <div class="form-control mb-4">
      <label class="label">
        <span class="label-text font-semibold">Worker Pool Max</span>
      </label>
      <input
        type="number"
        name="worker_pool_max"
        data-requires-restart="true"
        placeholder="0"
        class="input input-bordered w-24"
        min="0"
        value="{{ if .Config }}{{ .Config.WorkerPoolMax }}{{ end }}"
      />
      <label class="label">
        <span class="label-text-alt"
          >Maximum worker threads (0 = auto-calculate based on CPU cores).
          Restart required.</span
        >
      </label>
    </div>

    <div class="form-control mb-4">
      <label class="label">
        <span class="label-text font-semibold">Worker Pool Min Idle</span>
      </label>
      <input
        type="number"
        name="worker_pool_min_idle"
        data-requires-restart="true"
        placeholder="0"
        class="input input-bordered w-24"
        min="0"
        value="{{ if .Config }}{{ .Config.WorkerPoolMinIdle }}{{ end }}"
      />
      <label class="label">
        <span class="label-text-alt"
          >Minimum idle worker threads (0 = auto-calculate). Restart
          required.</span
        >
      </label>
    </div>

    <div class="form-control mb-4">
      <label class="label">
        <span class="label-text font-semibold">Worker Pool Max Idle Time</span>
      </label>
      <input
        type="text"
        name="worker_pool_max_idle_time"
        data-requires-restart="true"
        placeholder="10s"
        class="input input-bordered w-32"
        value="{{ if .Config }}{{ .Config.WorkerPoolMaxIdleTime }}{{ end }}"
      />
      <label class="label">
        <span class="label-text-alt"
          >Time before idle workers are terminated (e.g., 10s = 10 seconds).
          Restart required.</span
        >
      </label>
    </div>
  </fieldset>

  <fieldset
    class="fieldset border-base-300 bg-base-200/30 mb-6 rounded-lg border p-4"
  >
    <legend class="fieldset-legend text-base font-semibold">Queue</legend>
    <div class="form-control mb-4">
      <label class="label">
        <span class="label-text font-semibold">Queue Size</span>
      </label>
      <input
        type="number"
        name="queue_size"
        data-requires-restart="true"
        placeholder="10000"
        class="input input-bordered w-32"
        min="1"
        value="{{ if .Config }}{{ .Config.QueueSize }}{{ end }}"
      />
      <label class="label">
        <span class="label-text-alt"
          >Maximum size of the work queue. Restart required.</span
        >
      </label>
    </div>
  </fieldset>

  <fieldset
    class="fieldset border-base-300 bg-base-200/30 mb-6 rounded-lg border p-4"
  >
    <legend class="fieldset-legend text-base font-semibold">
      Cache Preload
    </legend>
    <div class="form-control mb-4">
      <label class="label cursor-pointer justify-start gap-4">
        <input
          type="checkbox"
          name="enable_cache_preload"
          class="checkbox checkbox-primary"
          {{ if and .Config .Config.EnableCachePreload }}checked{{ end }}
        />
        <span class="label-text font-semibold">Enable Cache Preload</span>
      </label>
      <label class="label">
        <span class="label-text-alt"
          >Pre-load HTTP cache entries when folders are opened for faster
          navigation.</span
        >
      </label>
    </div>
  </fieldset>
{{ end }}

{{ define "config-discovery-tab" }}
  <div class="form-control mb-4">
    <label class="label">
      <span class="label-text font-semibold">Run File Discovery</span>
    </label>
    <label class="label cursor-pointer justify-start gap-4">
      <input
        type="checkbox"
        name="run_file_discovery"
        class="checkbox checkbox-primary"
        {{ if and .Config .Config.RunFileDiscovery }}checked{{ end }}
      />
      <span class="label-text"
        >Automatically discover and index image files on startup</span
      >
    </label>
  </div>
{{ end }}

{{ define "config-admin-tab" }}
  <div class="form-control mb-4">
    <label class="label">
      <span class="label-text font-semibold">Admin User ID</span>
    </label>
    <input
      type="text"
      name="admin_username"
      placeholder="admin"
      class="input input-bordered w-64"
      value="{{ if .Username }}{{ .Username }}{{ end }}"
      minlength="8"
    />
    <label class="label">
      <span class="label-text-alt"
        >Admin username (minimum 8 characters, alphanumeric, underscore, or
        hyphen only)</span
      >
    </label>
  </div>

  <div class="form-control mb-4">
    <label class="label">
      <span class="label-text font-semibold">Current Password</span>
    </label>
    <div class="relative w-64">
      <input
        type="password"
        name="admin_current_password"
        placeholder="Enter current password"
        class="input input-bordered w-full pr-10"
        id="admin_current_password"
      />
      <button
        type="button"
        tabindex="-1"
        class="btn btn-ghost btn-sm absolute top-1/2 right-2 h-auto min-h-0 -translate-y-1/2 p-1"
        id="toggle_admin_current_password"
        _="on click
           set input to #admin_current_password
           if input.type == 'password'
             set input.type to 'text'
             set my.innerHTML to '👁️'
           else
             set input.type to 'password'
             set my.innerHTML to '👁️‍🗨️'
           end"
      >
        👁️‍🗨️
      </button>
    </div>
    <label class="label">
      <span class="label-text-alt"
        >Required to authorize any credential changes</span
      >
    </label>
  </div>

  <div class="form-control mb-4">
    <label class="label">
      <span class="label-text font-semibold">New Password</span>
    </label>
    <div class="relative w-64">
      <input
        type="password"
        name="admin_new_password"
        placeholder="Enter new password"
        class="input input-bordered w-full pr-10"
        id="admin_new_password"
        minlength="8"
      />
      <button
        type="button"
        tabindex="-1"
        class="btn btn-ghost btn-sm absolute top-1/2 right-2 h-auto min-h-0 -translate-y-1/2 p-1"
        id="toggle_admin_new_password"
        _="on click
           set input to #admin_new_password
           if input.type == 'password'
             set input.type to 'text'
             set my.innerHTML to '👁️'
           else
             set input.type to 'password'
             set my.innerHTML to '👁️‍🗨️'
           end"
      >
        👁️‍🗨️
      </button>
    </div>
    <div
      id="admin_new_password_error"
      class="label-text-alt text-error hidden"
    ></div>
    <label class="label">
      <span class="label-text-alt"
        >Minimum 8 characters, must include: 1 uppercase, 1 lowercase, 1 number,
        1 special character</span
      >
    </label>
  </div>

  <div class="form-control mb-4">
    <label class="label">
      <span class="label-text font-semibold">Confirm Password</span>
    </label>
    <div class="relative w-64">
      <input
        type="password"
        name="admin_confirm_password"
        placeholder="Confirm new password"
        class="input input-bordered w-full pr-10"
        id="admin_confirm_password"
        minlength="8"
      />
      <button
        type="button"
        tabindex="-1"
        class="btn btn-ghost btn-sm absolute top-1/2 right-2 h-auto min-h-0 -translate-y-1/2 p-1"
        id="toggle_admin_confirm_password"
        _="on click
           set input to #admin_confirm_password
           if input.type == 'password'
             set input.type to 'text'
             set my.innerHTML to '👁️'
           else
             set input.type to 'password'
             set my.innerHTML to '👁️‍🗨️'
           end"
      >
        👁️‍🗨️
      </button>
    </div>
    <div
      id="admin_confirm_password_error"
      class="label-text-alt text-error hidden"
    ></div>
    <label class="label">
      <span class="label-text-alt">Must match new password</span>
    </label>
  </div>

  <script type="text/javascript">
    function checkPasswordValid(password) {
      const regex =
        /^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[!@#$%^&*()_+\-=\[\]{};':"\\|,.<>\/?]).{8,}$/;
      return regex.test(password);
    }

    function validateNewPassword() {
      const newPass = document.getElementById("admin_new_password").value;
      const errorMsg = document.getElementById("admin_new_password_error");
      const inputEl = document.getElementById("admin_new_password");
      const confirmPass = document.getElementById(
        "admin_confirm_password",
      ).value;
      const confirmErrorMsg = document.getElementById(
        "admin_confirm_password_error",
      );

      if (newPass === "") {
        errorMsg.classList.add("hidden");
        inputEl.classList.remove("input-error");
      } else if (!checkPasswordValid(newPass)) {
        errorMsg.classList.remove("hidden");
        errorMsg.textContent =
          "Password must contain at least one uppercase, one lowercase, one number, and one special character";
        inputEl.classList.add("input-error");
      } else {
        errorMsg.classList.add("hidden");
        inputEl.classList.remove("input-error");
      }

      // Also validate password match when new password changes
      if (newPass !== "" && confirmPass !== "" && newPass !== confirmPass) {
        confirmErrorMsg.classList.remove("hidden");
        confirmErrorMsg.textContent = "Passwords do not match";
        document
          .getElementById("admin_confirm_password")
          .classList.add("input-error");
      } else if (
        newPass !== "" &&
        confirmPass !== "" &&
        newPass === confirmPass
      ) {
        confirmErrorMsg.classList.add("hidden");
        document
          .getElementById("admin_confirm_password")
          .classList.remove("input-error");
      } else {
        confirmErrorMsg.classList.add("hidden");
        document
          .getElementById("admin_confirm_password")
          .classList.remove("input-error");
      }
    }

    function validateConfirmPassword() {
      const newPass = document.getElementById("admin_new_password").value;
      const confirmPass = document.getElementById(
        "admin_confirm_password",
      ).value;
      const errorMsg = document.getElementById("admin_confirm_password_error");
      const inputEl = document.getElementById("admin_confirm_password");

      if (newPass !== "" && confirmPass !== "" && newPass !== confirmPass) {
        errorMsg.classList.remove("hidden");
        errorMsg.textContent = "Passwords do not match";
        inputEl.classList.add("input-error");
      } else if (
        newPass !== "" &&
        confirmPass !== "" &&
        newPass === confirmPass
      ) {
        errorMsg.classList.add("hidden");
        inputEl.classList.remove("input-error");
      } else {
        errorMsg.classList.add("hidden");
        inputEl.classList.remove("input-error");
      }
    }

    document.addEventListener("DOMContentLoaded", function () {
      const newPasswordInput = document.getElementById("admin_new_password");
      const confirmPasswordInput = document.getElementById(
        "admin_confirm_password",
      );

      if (newPasswordInput) {
        newPasswordInput.addEventListener("input", validateNewPassword);
      }

      if (confirmPasswordInput) {
        confirmPasswordInput.addEventListener("input", validateConfirmPassword);
      }
    });
  </script>
{{ end }}
