      class="select select-bordered w-48"
      id="default-theme-select"
    >
      {{ if .Config.Themes }}
        {{ range .Config.Themes }}
          <option
            value="{{ . }}"
            {{ if and $.Config (eq $.Config.CurrentTheme .) }}selected{{ end }}
          >
            {{ . }}
          </option>
        {{ end }}
      {{ else }}
        <option
          value="dark"
          {{ if and .Config (eq .Config.CurrentTheme "dark") }}selected{{ end }}
        >
          dark
        </option>
        <option
          value="light"
          {{ if and .Config (eq .Config.CurrentTheme "light") }}
            selected
          {{ end }}
        >
          light
        </option>
      {{ end }}
    </select>
    <label class="label">
      <span class="label-text-alt"
        >Default theme for the UI (must be one of the selected themes
        above)</span
      >
    </label>
    <div id="theme-validation-error" class="text-error mt-1 hidden text-sm">
      Default theme must be one of the selected themes
    </div>
  </div>

  <script type="text/hyperscript">
    /* Update default theme dropdown when themes checkboxes change */
    on change from .theme-checkbox
      set selectEl to #default-theme-select
      set currentValue to selectEl.value
      set selectEl.innerHTML to ''
      set checkboxes to document.querySelectorAll('input[name="themes"]:checked')
      set isValid to false
      set firstTheme to null

      /* Build dropdown options and check validation */
      for checkbox in checkboxes
        set theme to checkbox.value
        if firstTheme is null set firstTheme to theme end
        if theme == currentValue set isValid to true end

        set option to document.createElement('option')
        set option.value to theme
        set option.textContent to theme.charAt(0).toUpperCase() + theme.slice(1)
        if theme == currentValue set option.selected to true end
        call selectEl.appendChild(option)
      end

      /* Validate and update selection */
      if checkboxes.length == 0
        remove .hidden from #theme-validation-error
      else if not isValid
        if firstTheme is not null
          set selectEl.value to firstTheme
        end
        add .hidden to #theme-validation-error
      else
        add .hidden to #theme-validation-error
      end
    end
  </script>
{{ end }}

