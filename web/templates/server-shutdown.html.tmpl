{{ define "body" }}
  <div class="hero bg-base-200 min-h-[60vh]">
    <div class="hero-content text-center">
      <div class="max-w-md">
        <div class="mb-6 flex justify-center">
          <span class="loading loading-ring loading-lg text-primary"></span>
        </div>
        <h1 class="mb-4 text-4xl font-bold">Shutting Down</h1>
        <p class="text-base-content/70 mb-6 text-lg">
          The server is shutting down gracefully. All pending operations are
          being completed.
        </p>
        <div class="alert alert-info">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-6 w-6 shrink-0 stroke-current"
            fill="none"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
            />
          </svg>
          <span
            >You can close this window. The server will be unavailable until
            restarted.</span
          >
        </div>
      </div>
    </div>
  </div>
{{ end }}
