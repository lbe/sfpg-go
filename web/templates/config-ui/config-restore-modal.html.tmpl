<div
  class="modal-box max-h-[90vh] max-w-4xl"
  _="init set #restore-diff-modal-toggle.checked to true"
>
  <h3 class="mb-4 text-lg font-bold">Restore Configuration</h3>
  <p class="mb-4">
    You are about to restore the last known good configuration. This will
    overwrite your current configuration. Review the changes before proceeding:
  </p>
  <textarea name="yaml" id="restore-yaml-content" class="hidden">
{{ .BackupYAML }}</textarea
  >
  <input
    type="hidden"
    name="csrf_token"
    id="restore-csrf-token"
    value="{{ .CSRFToken }}"
  />
  <div class="mb-4 grid grid-cols-2 gap-4">
    <div>
      <h4 class="mb-2 font-semibold">Current Configuration</h4>
      <pre
        class="bg-base-200 max-h-[50vh] overflow-auto rounded-lg p-4 text-xs whitespace-pre-wrap"
      >
{{ .CurrentYAML }}</pre
      >
    </div>
    <div>
      <h4 class="mb-2 font-semibold">Last Known Good Configuration</h4>
      <pre
        class="bg-base-200 max-h-[50vh] overflow-auto rounded-lg p-4 text-xs whitespace-pre-wrap"
      >
{{ .BackupYAML }}</pre
      >
    </div>
  </div>
  <div class="modal-action">
    <label for="restore-diff-modal-toggle" class="btn">Cancel</label>
    <button
      class="btn btn-primary"
      hx-post="/config/restore/commit"
      hx-swap="none"
      hx-include="#restore-yaml-content,#restore-csrf-token"
    >
      Restore
    </button>
  </div>
</div>
<label class="modal-backdrop" for="restore-diff-modal-toggle">Close</label>
