{{ if .RestartRequired }}
  <div
    id="config-success-message"
    class="alert alert-warning mb-2"
    hx-swap-oob="outerHTML"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      class="h-6 w-6 shrink-0 stroke-current"
      fill="none"
      viewBox="0 0 24 24"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"
      />
    </svg>
    <span
      >Last known good configuration restored successfully. Server restart
      required.</span
    >
  </div>
{{ else }}
  <div
    id="config-success-message"
    class="alert alert-success mb-2"
    hx-swap-oob="outerHTML"
    _="on load
      wait 2s
      set #config_modal.checked to false
      wait 300ms
      remove #config-modal-container from body"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      class="h-6 w-6 shrink-0 stroke-current"
      fill="none"
      viewBox="0 0 24 24"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
      />
    </svg>
    <span>Last known good configuration restored successfully</span>
  </div>
{{ end }}
<div id="config-error-message" hx-swap-oob="outerHTML"></div>
<div></div>
